#!/usr/bin/env bash
# FLOW dispatcher — routes subcommands to Rust (if available) or lib/*.py.
#
# Usage: bin/flow <subcommand> [args...]
# Example: bin/flow start-setup "Invoice Pdf Export"
#
# Hybrid dispatch: tries the Rust binary first. If it exits 127
# (unknown subcommand), falls back to Python. Any other exit code
# from Rust is passed through directly.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="$SCRIPT_DIR/../lib"

if [ $# -eq 0 ]; then
  echo '{"status":"error","message":"Usage: bin/flow <subcommand> [args...]"}'
  exit 1
fi

subcmd="$1"
shift

# Try Rust binary first (hybrid dispatcher)
RUST_BIN=""
if [ -x "$SCRIPT_DIR/../target/release/flow-rs" ]; then
  RUST_BIN="$SCRIPT_DIR/../target/release/flow-rs"
elif [ -x "$SCRIPT_DIR/../target/debug/flow-rs" ]; then
  RUST_BIN="$SCRIPT_DIR/../target/debug/flow-rs"
fi

# Auto-rebuild stale Rust binary
REPO_ROOT="$SCRIPT_DIR/.."
if [ -f "$REPO_ROOT/Cargo.toml" ] && [ -d "$REPO_ROOT/src" ]; then
  needs_build=false
  if [ -z "$RUST_BIN" ]; then
    needs_build=true
  elif find "$REPO_ROOT/src" "$REPO_ROOT/Cargo.toml" -newer "$RUST_BIN" -print -quit 2>/dev/null | grep -q .; then
    needs_build=true
  fi
  if [ "$needs_build" = true ]; then
    if cargo build --manifest-path "$REPO_ROOT/Cargo.toml" 2>/dev/null; then
      # Re-resolve after successful build
      RUST_BIN=""
      if [ -x "$REPO_ROOT/target/release/flow-rs" ]; then
        RUST_BIN="$REPO_ROOT/target/release/flow-rs"
      elif [ -x "$REPO_ROOT/target/debug/flow-rs" ]; then
        RUST_BIN="$REPO_ROOT/target/debug/flow-rs"
      fi
    fi
  fi
fi

if [ -n "$RUST_BIN" ]; then
  set +e
  "$RUST_BIN" "$subcmd" "$@"
  rc=$?
  set -e
  if [ $rc -ne 127 ]; then
    exit $rc
  fi
  # Exit 127 = unknown subcommand, fall through to Python
fi

# Python fallback
script="$LIB_DIR/$subcmd.py"

if [ ! -f "$script" ]; then
  echo "{\"status\":\"error\",\"message\":\"Unknown subcommand: $subcmd\"}"
  exit 1
fi

exec python3 "$script" "$@"
