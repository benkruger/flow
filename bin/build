#!/usr/bin/env bash
# FLOW build — called by `bin/flow ci --build`.
#
# In this repo the build step is folded into bin/test (cargo-llvm-cov
# nextest compiles the library, main binary, and every integration
# test harness as part of its instrumented run). A separate cargo
# build here would duplicate that work. See CLAUDE.md and
# .claude/rules/tool-dispatch.md.
set -euo pipefail
echo "bin/build: no-op — compilation happens in bin/test (cargo-llvm-cov nextest). Run bin/flow ci --test." >&2
exit 0
