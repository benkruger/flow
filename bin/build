#!/usr/bin/env bash
# FLOW build — called by `bin/flow build` and `bin/flow ci`.
# Compiles the workspace; nonzero exit blocks downstream CI steps.
set -euo pipefail

# === GATE 1: warnings-as-errors (ENABLED) ===
# -D warnings: zero-tolerance policy — any compile warning fails the build.
export RUSTFLAGS="${RUSTFLAGS:-} -D warnings"

exec cargo build
