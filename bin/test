#!/usr/bin/env bash
# FLOW test runner — called by `bin/flow ci` (and `bin/flow ci --test`).
#
# Modes:
#   bin/test                                  — full suite; fail fast on any issue
#   bin/test --audit                          — full suite; never fails, logs to
#                                               .flow-states/<branch>-audit.log,
#                                               prints terse summary, exit 0
#   bin/test tests/<path>/<name>.rs           — per-file mode; fail fast
#   bin/test tests/<path>/<name>.rs --audit   — per-file mode; never fails
#   bin/test --file <path> [args...]          — single file via rustc --test (dev)
#   bin/test --check <module> [args...]       — fast lib tests, no coverage (dev)
#   bin/test --report                         — re-render cached coverage (dev)
#   bin/test --show <file>                    — annotated source (dev)
#   bin/test --module <name>                  — per-module lib coverage (dev)
#
# Trailing args after `--` on `bin/flow ci --test` forward here as
# filter expressions for nextest.
set -euo pipefail

export RUSTFLAGS="${RUSTFLAGS:-} -D warnings"
export LLVM_COV=/opt/homebrew/opt/llvm/bin/llvm-cov
export LLVM_PROFDATA=/opt/homebrew/opt/llvm/bin/llvm-profdata

# Full-suite wall time gate. Per-test gate lives in
# .config/nextest.toml as `slow-timeout` with `terminate-after=1`
# (currently 2s, temporarily relaxed from the 1s target while the
# slow-test backlog clears). Per-file timing gate is intentionally
# absent — per-test discipline subsumes it.
SUITE_TIMEOUT_SECS=180

# --- Global flag parsing ---
AUDIT_MODE=0
PASS_THROUGH=()
for arg in "$@"; do
  case "$arg" in
    --audit) AUDIT_MODE=1 ;;
    *) PASS_THROUGH+=("$arg") ;;
  esac
done
if [ "${#PASS_THROUGH[@]}" -gt 0 ]; then
  set -- "${PASS_THROUGH[@]}"
else
  set --
fi

# --- Dev-only modes (unchanged behavior) ---

if [ "${1:-}" = "--file" ]; then
  shift
  file="$1"
  shift
  temp_bin=".flow-test-binary"
  trap 'rm -f "$temp_bin"' EXIT
  rustc --test "$file" -o "$temp_bin"
  ./"$temp_bin" "$@"
  exit
fi

if [ "${1:-}" = "--check" ]; then
  shift
  module="$1"
  shift
  exec cargo nextest run --lib -E "test(${module})" "$@"
fi

if [ "${1:-}" = "--report" ]; then
  shift
  exec cargo llvm-cov report --show-missing-lines "$@"
fi

if [ "${1:-}" = "--show" ]; then
  shift
  file="$1"
  shift
  exec cargo llvm-cov report --text --show-instantiations \
    --ignore-filename-regex "^(?!.*${file//./\\.}$).*$" \
    "$@"
fi

if [ "${1:-}" = "--module" ]; then
  shift
  module="$1"
  shift
  echo "=== Running lib tests matching '${module}' ==="
  cargo llvm-cov --lib nextest \
    --no-cfg-coverage \
    --no-clean \
    --status-level pass \
    --final-status-level fail \
    -E "test(${module})" \
    "$@" 2>&1 | awk '
      /^ *PASS / { printf "."; c++; fflush(); next }
      { if (c > 0) { printf "\n\n"; c = 0 } print; fflush() }
      END { if (c > 0) printf "\n" }'
  echo ""
  echo "=== Coverage for ${module} ==="
  cargo llvm-cov report --show-missing-lines 2>&1 | awk -v m="${module}" '
    BEGIN { in_uncov = 0 }
    /^Filename/ { hdr=$0; sep_print=0; next }
    /^---/ { if (sep_print == 0) { sep=$0; sep_print=1 } next }
    /^TOTAL/ { next }
    /^Uncovered Lines:/ { in_uncov = 1; print ""; print "--- Uncovered lines ---"; next }
    in_uncov == 1 {
      if ($1 ~ ("(/|^)" m "\\.rs:$") || $1 ~ ("(/|^)" m "/.+\\.rs:$")) print
      next
    }
    $1 ~ ("(/|^)" m "\\.rs$") || $1 ~ ("(/|^)" m "/.+\\.rs$") {
      if (printed == 0) { print hdr; print sep; printed = 1 }
      print
    }
  '
  exit
fi

# --- Unconditional profraw sweep ---
/usr/bin/find target/llvm-cov-target -maxdepth 1 -name "*.profraw" -delete 2>/dev/null || true
/usr/bin/find . -maxdepth 1 -name "default_*.profraw" -delete 2>/dev/null || true

# --- Resolve the audit log path (branch-scoped). ---
# Per FLOW's concurrency model (CLAUDE.md "Local vs Shared State"),
# per-branch artifacts live under .flow-states/ keyed by branch name.
# Using PID would namespace per-process but ignore the branch the run
# is auditing, which is the natural unit for a test-run record.
branch_for_audit() {
  local b
  b="$(git branch --show-current 2>/dev/null || true)"
  if [ -z "$b" ]; then
    b="detached"
  fi
  echo "$b"
}

# --- Per-file mode: bin/test tests/<path>/<name>.rs ---
case "${1:-}" in
  tests/*.rs) PER_FILE=1 ;;
  *) PER_FILE=0 ;;
esac

if [ "$PER_FILE" = "1" ]; then
  test_file="$1"
  shift
  if [ ! -f "$test_file" ]; then
    echo "error: test file not found: $test_file" >&2
    exit 1
  fi
  src_file="${test_file/#tests\//src/}"
  bin_name="$(basename "$test_file" .rs)"

  NEXTEST_ARGS=(--status-level pass --final-status-level fail -E "binary(${bin_name})")
  COV_ARGS=(--no-cfg-coverage --no-clean)

  if [ "$AUDIT_MODE" = "1" ]; then
    # Audit bypasses cargo-llvm-cov — its own `--profile` flag
    # conflicts with nextest's, swallowing the audit-profile
    # selection. Audit is a diagnostic (find slow/failing tests),
    # so coverage measurement is out of scope here.
    NEXTEST_ARGS+=(--no-fail-fast --profile audit)
    mkdir -p .flow-states
    branch="$(branch_for_audit)"
    run_log=".flow-states/${branch}-audit.log"
    : > "$run_log"
    echo "=== ${bin_name} audit (log: ${run_log}) ==="
    time_start=$SECONDS
    cargo nextest run "${NEXTEST_ARGS[@]}" "$@" >>"$run_log" 2>&1 || true
    elapsed=$((SECONDS - time_start))
    # With profile.audit (no terminate-after), slow tests run to
    # completion; SLOW lines only fire at 60s boundaries. Count
    # unique slow/failed test names, trimming whitespace and
    # stripping ANSI escapes. `set +e` guards against grep
    # returning 1 when no matches exist.
    set +e
    slow_count="$(grep -E '^ *SLOW ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
    fail_count="$(grep -E '^ *FAIL ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
    set -e
    echo "Wall time: ${elapsed}s"
    echo "Slow tests (>60s): ${slow_count}"
    echo "Failed tests: ${fail_count}"
    echo "Full log: ${run_log}"
    exit 0
  fi

  # Normal per-file: fail fast on any issue (nextest's fail-fast +
  # terminate-after handle test/timing failures).
  #
  # Coverage enforcement is a two-step: first run nextest under
  # cargo-llvm-cov with `--no-report` so profraw is captured but no
  # threshold check runs; then invoke `cargo llvm-cov report
  # --fail-under-* --ignore-filename-regex` to scope the threshold
  # to the mirrored src file. Doing it in one command (`cargo
  # llvm-cov --fail-under-* nextest ...`) computes the threshold
  # against the full codebase totals, ignoring the filter — the
  # subcommand form only applies the regex to the printed table,
  # not to the fail-under calculation.
  if [ -f "$src_file" ]; then
    echo "=== ${bin_name} (mirrored src: ${src_file}) ==="
    time_start=$SECONDS
    # Step 1: run tests (cargo-llvm-cov captures profraw, no
    # threshold gate yet — we extract the per-file number in
    # step 2 below).
    set +e
    cargo llvm-cov --no-cfg-coverage --no-clean nextest \
      "${NEXTEST_ARGS[@]}" "$@"
    rc=$?
    set -e
    if [ "$rc" -ne 0 ]; then
      exit "$rc"
    fi
    # Step 2: extract the coverage row for the mirrored src file
    # and assert all three percentages (Regions, Functions, Lines)
    # read 100.00%. We can't use cargo-llvm-cov's
    # `--ignore-filename-regex + --fail-under-*` combination
    # because llvm-cov's regex engine doesn't honor negative
    # lookahead, so the filter silently matches nothing and the
    # threshold evaluates against the full-codebase total.
    #
    # Basenames are unique across src/ in this codebase (verified
    # by `tests/test_placement.rs` indirectly; enforced in practice
    # by the flat-basename convention). Matching on the basename
    # with a trailing whitespace boundary guards against partial
    # matches like `commands/log.rs` being matched by `log.rs`.
    basename_src="$(basename "$src_file")"
    cov_report="$(cargo llvm-cov report 2>&1)"
    cov_line="$(printf '%s\n' "$cov_report" | awk -v f="$basename_src" '
      # Match any line whose first column ends with "/<basename>"
      # or equals "<basename>" exactly.
      $1 == f || $1 ~ "/" f "$" { print; exit }
    ')"
    echo ""
    echo "=== Coverage gate for ${src_file} ==="
    if [ -z "$cov_line" ]; then
      # cargo-llvm-cov omits files with zero instrumented regions
      # (e.g., a file that only contains derive macros or type
      # declarations — no executable code to cover). A file with
      # zero regions is trivially at 100% because there is nothing
      # to miss. Treat this as PASS.
      echo "${src_file}: no instrumented regions (trivially 100/100/100)"
    else
      echo "$cov_line"
      # Report layout: Regions cover in col 4, Functions cover
      # (labeled "Executed") in col 7, Lines cover in col 10. All
      # three must read 100.00%.
      if ! printf '%s\n' "$cov_line" | awk '
        { exit ($4 == "100.00%" && $7 == "100.00%" && $10 == "100.00%") ? 0 : 1 }
      '; then
        echo "" >&2
        echo "FAIL: ${src_file} is not at 100/100/100" >&2
        exit 1
      fi
    fi
    elapsed=$((SECONDS - time_start))
    echo ""
    echo "=== PASS (${elapsed}s) ==="
    exit 0
  fi

  # Meta-test (no mirrored src) — no coverage gate.
  echo "=== ${bin_name} (meta-test, no mirrored src) ==="
  temp_log="$(mktemp -t flow-test-log.XXXXXX)"
  trap 'rm -f "$temp_log"' EXIT
  time_start=$SECONDS
  set +e
  cargo llvm-cov "${COV_ARGS[@]}" nextest "${NEXTEST_ARGS[@]}" "$@" 2>&1 \
    | tee "$temp_log" \
    | awk '
/^ *PASS / { printf "."; c++; fflush(); next }
{ if (c > 0) { printf "\n"; c = 0 } print; fflush() }
END { if (c > 0) printf "\n" }'
  rc="${PIPESTATUS[0]}"
  set -e
  if [ "$rc" -ne 0 ]; then
    exit "$rc"
  fi
  elapsed=$((SECONDS - time_start))
  echo ""
  echo "=== PASS (${elapsed}s) ==="
  exit 0
fi

# --- Full-suite mode ---

if [ $# -eq 0 ]; then
  cargo sweep --installed --target-dir target/llvm-cov-target >/dev/null 2>&1 || true
fi
if [ $# -eq 0 ] && [ "${FLOW_CI_FORCE:-}" != "1" ]; then
  cargo clean --target-dir target/llvm-cov-target -p flow-rs
fi

NEXTEST_ARGS=(--status-level pass --final-status-level fail)
COV_ARGS=(--no-cfg-coverage --no-clean)

if [ "$AUDIT_MODE" = "1" ]; then
  # Audit bypasses cargo-llvm-cov entirely — its own `--profile`
  # flag conflicts with nextest's `--profile`, swallowing the
  # audit-profile selection. Since audit is a diagnostic tool
  # (find slow tests, find failing tests), coverage measurement
  # is out of scope; regular `bin/flow ci` carries the coverage
  # gate.
  NEXTEST_ARGS+=(--no-fail-fast --profile audit)
  mkdir -p .flow-states
  branch="$(branch_for_audit)"
  run_log=".flow-states/${branch}-audit.log"
  : > "$run_log"
  echo "=== Full-suite audit (log: ${run_log}) ==="
  time_start=$SECONDS
  cargo nextest run "${NEXTEST_ARGS[@]}" "$@" >>"$run_log" 2>&1 || true
  elapsed=$((SECONDS - time_start))
  # Count unique slow/failed test names. With profile.audit
  # (no terminate-after), slow tests run to completion; actual
  # durations appear in PASS/FAIL lines and SLOW warnings appear
  # at 60s boundaries. `|| true` keeps set -e from exiting when
  # grep finds no matches; `wc -l | tr -d ' '` normalizes count.
  set +e
  slow_count="$(grep -E '^ *SLOW ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
  fail_count="$(grep -E '^ *FAIL ' "$run_log" 2>/dev/null | sed -E $'s/\x1b\\[[0-9;]*m//g' | awk '{print $NF}' | tr -d ' \t\r' | sort -u | wc -l | tr -d ' ')"
  set -e
  echo "Wall time: ${elapsed}s"
  echo "Slow tests (>60s): ${slow_count}"
  echo "Failed tests: ${fail_count}"
  echo "Full log: ${run_log}"
  exit 0
fi

# Normal full-suite: fail fast on any issue.
#
# Coverage thresholds only apply when the run actually covers the
# whole suite — i.e., no filter args were passed. A filtered run
# (e.g. `bin/flow ci --test -- foo::bar`) exercises a subset of
# tests, so measuring total coverage against 100% is meaningless
# and would always fail the build. The filter path's job is to
# prove the specific test passes and respects the 2s gate; the
# full suite's job is to enforce 100/100/100 coverage globally.
if [ $# -eq 0 ]; then
  COV_ARGS+=(--fail-under-lines 100 --fail-under-regions 100 --fail-under-functions 100)
fi
temp_log="$(mktemp -t flow-test-log.XXXXXX)"
trap 'rm -f "$temp_log"' EXIT
time_start=$SECONDS
set +e
cargo llvm-cov "${COV_ARGS[@]}" nextest "${NEXTEST_ARGS[@]}" "$@" 2>&1 \
  | tee "$temp_log" \
  | awk '
/^ *PASS / { printf "."; c++; fflush(); next }
{
  if (c > 0) { printf "\n"; c = 0 }
  s = $0
  n = gsub(/100\.00%/, "&", s)
  if (n >= 3) next
  print
  fflush()
}
END { if (c > 0) printf "\n" }'
rc="${PIPESTATUS[0]}"
set -e

if [ "$rc" -ne 0 ]; then
  exit "$rc"
fi
# Slow tests are terminated by nextest (terminate-after=1) and
# appear as TIMEOUT failures, already caught by the rc check above.
elapsed=$((SECONDS - time_start))
if [ "$elapsed" -gt "$SUITE_TIMEOUT_SECS" ]; then
  echo ""
  echo "=== FAIL: suite took ${elapsed}s, limit ${SUITE_TIMEOUT_SECS}s ==="
  exit 1
fi
echo ""
echo "=== PASS (${elapsed}s) ==="
exit 0
