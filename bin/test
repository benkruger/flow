#!/usr/bin/env bash
# FLOW test runner — called by `bin/flow ci` (and `bin/flow ci --test`).
#
# Two modes:
#   bin/test                                 — full suite via cargo llvm-cov + nextest
#   bin/test --file <path> [extra args...]   — single test file via rustc --test
#
# Trailing args after `--` are forwarded to nextest as filter expressions.
set -euo pipefail

# Warnings-as-errors: any compile warning fails the build.
export RUSTFLAGS="${RUSTFLAGS:-} -D warnings"

# cargo-llvm-cov tool paths (Homebrew LLVM).
export LLVM_COV=/opt/homebrew/opt/llvm/bin/llvm-cov
export LLVM_PROFDATA=/opt/homebrew/opt/llvm/bin/llvm-profdata

if [ "${1:-}" = "--file" ]; then
  shift
  file="$1"
  shift
  temp_bin=".flow-test-binary"
  trap 'rm -f "$temp_bin"' EXIT
  rustc --test "$file" -o "$temp_bin"
  ./"$temp_bin" "$@"
  exit
fi

# `bin/test --check <module>` runs lib tests for a module WITHOUT
# coverage instrumentation. Fast iteration loop (~1-2s) for verifying
# test correctness during development. Use `bin/test --module` to
# verify coverage after tests pass.
if [ "${1:-}" = "--check" ]; then
  shift
  module="$1"
  shift
  exec cargo nextest run --lib -E "test(${module})" "$@"
fi

# `bin/test --report` re-renders the cached coverage data with
# missing-line numbers. Requires a prior full-suite run to have
# populated target/llvm-cov-target/. Read-only; no rebuild.
if [ "${1:-}" = "--report" ]; then
  shift
  exec cargo llvm-cov report --show-missing-lines "$@"
fi

# `bin/test --show <file>` renders annotated source with per-region
# and per-instantiation counts for one file. Used to diagnose
# uncovered regions that don't surface in the `--report` per-file
# Uncovered Lines list — typically generic monomorphizations whose
# region misses are tallied but not pinned to a source line.
# Read-only; no rebuild. Requires a prior coverage run.
if [ "${1:-}" = "--show" ]; then
  shift
  file="$1"
  shift
  # Restrict the annotated output to this one file via an exclusion
  # regex over every other path. Pass `--text --show-instantiations`
  # so each monomorphization renders on its own with `^N` per-region
  # counts.
  exec cargo llvm-cov report --text --show-instantiations \
    --ignore-filename-regex "^(?!.*${file//./\\.}$).*$" \
    "$@"
fi

# `bin/test --module <name>` runs every test whose name contains
# <name> (intended to match a single src module like `add_finding`),
# then renders coverage for ONLY that file (and its inline tests).
# Used to iterate per-file fast: typical compile + run cycle is
# 25-40s instead of the 4-minute full ci. Subsequent runs against
# the same module skip recompile entirely (`--no-clean`).
#
# Limitation: the report's TOTAL line is from the cached merged
# data, so it can be stale. The per-file row is fresh because the
# tests we just ran refreshed THAT file's profraw.
if [ "${1:-}" = "--module" ]; then
  shift
  module="$1"
  shift
  # `--lib` skips compiling/running integration test binaries (tests/*.rs),
  # leaving only the library + its inline #[cfg(test)] modules. This drops
  # cycle time from minutes to seconds because all 87 integration test
  # binaries are bypassed. Coverage from subprocess integration tests is
  # NOT included — use full `bin/flow ci` for the authoritative number.
  echo "=== Running lib tests matching '${module}' ==="
  cargo llvm-cov --lib nextest \
    --no-cfg-coverage \
    --no-clean \
    --status-level pass \
    --final-status-level fail \
    -E "test(${module})" \
    "$@" 2>&1 | awk '
      /^ *PASS / { printf "."; c++; fflush(); next }
      { if (c > 0) { printf "\n\n"; c = 0 } print; fflush() }
      END { if (c > 0) printf "\n" }'
  echo ""
  echo "=== Coverage for ${module} ==="
  cargo llvm-cov report --show-missing-lines 2>&1 | awk -v m="${module}" '
    BEGIN { in_uncov = 0 }
    /^Filename/ { hdr=$0; sep_print=0; next }
    /^---/ { if (sep_print == 0) { sep=$0; sep_print=1 } next }
    /^TOTAL/ { next }
    /^Uncovered Lines:/ { in_uncov = 1; print ""; print "--- Uncovered lines ---"; next }
    in_uncov == 1 {
      if ($1 ~ ("(/|^)" m "\\.rs:$") || $1 ~ ("(/|^)" m "/.+\\.rs:$")) print
      next
    }
    $1 ~ ("(/|^)" m "\\.rs$") || $1 ~ ("(/|^)" m "/.+\\.rs$") {
      if (printed == 0) { print hdr; print sep; printed = 1 }
      print
    }
  '
  exit
fi

# Full-suite invocations (no filter args) are the CI gate. They must
# rebuild flow-rs artifacts from clean so llvm-cov measures a single,
# coherent source generation.
#
# `--no-clean` (set below) preserves accumulated instrumented binaries
# across runs so filtered iteration is fast. On a long-lived target
# dir — notably main's, where start-gate runs CI every flow-start as
# PRs merge and source evolves — stale flow-rs binaries accumulate.
# Each binary embeds its own coverage map (`.covmap`) describing the
# source layout it was compiled against. llvm-cov merges ALL binaries
# present, so a pre-refactor binary's 4000-region analyze_issues.rs
# covmap silently poisons the post-refactor binary's 2300-region
# covmap, producing Frankenstein coverage numbers that look like a
# regression but aren't.
#
# Cleaning flow-rs at the package scope removes stale binaries while
# keeping the dep cache (`target/llvm-cov-target/debug/deps/*` for
# serde, regex, etc.) warm, so rebuild is package-scoped rather than
# from-zero. Filtered runs (`bin/flow ci --test -- <filter>`) skip this
# branch entirely and keep the full incremental cache.
#
# The profraw sweep following the clean removes accumulated coverage
# samples from prior binaries so `llvm-profdata merge` does not stall
# chewing through stale data carried forward by `--no-clean`.
if [ $# -eq 0 ] && [ "${FLOW_CI_FORCE:-}" != "1" ]; then
  cargo clean --target-dir target/llvm-cov-target -p flow-rs
  /usr/bin/find target/llvm-cov-target -maxdepth 1 -name "*.profraw" -delete 2>/dev/null || true
  # Sweep worktree-root profraw leaks — subprocess tests whose cwd lands
  # here when cargo-llvm-cov's LLVM_PROFILE_FILE template can't resolve.
  /usr/bin/find . -maxdepth 1 -name "default_*.profraw" -delete 2>/dev/null || true
fi

# Coverage gate. Pinned at 100/100/100 — any uncovered region,
# function, or line fails CI and blocks the commit. No ratchet, no
# floor, no waivers. Code that appears uncoverable must be
# refactored until it is testable. See .claude/rules/no-waivers.md.
# Merge stderr+stdout through awk so nextest sees a non-TTY (no animated
# progress bar dumping hundreds of frames). The awk filter:
#   - Converts each PASS line to a dot (wraps at terminal width)
#   - Prints FAIL lines in full
#   - Skips coverage files where all three metrics are 100.00%
#   - Passes everything else through (compile output, summary, TOTAL, errors)
# --status-level pass: nextest prints one line per passing test (fuel for dots)
# --final-status-level fail: failures in the end-of-run summary (leaky tests
#   produce LEAK lines during the run which pass through the awk filter in full)
# pipefail (set above) preserves cargo llvm-cov's exit code.
cargo llvm-cov --no-cfg-coverage --no-clean \
  --fail-under-lines 100 \
  --fail-under-regions 100 \
  --fail-under-functions 100 \
  nextest --status-level pass --final-status-level fail "$@" 2>&1 | awk '
/^ *PASS / {
  printf "."
  c++
  fflush()
  next
}
{
  if (c > 0) { printf "\n\n"; c = 0 }
  s = $0
  n = gsub(/100\.00%/, "&", s)
  if (n >= 3) next
  print
  fflush()
}
END {
  if (c > 0) printf "\n"
}'
