#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SECRETS_FILE="$PROJECT_DIR/FlowQA/Secrets.swift"
SECRETS_EXAMPLE="$PROJECT_DIR/FlowQA/Secrets.swift.example"
if [ ! -f "$SECRETS_FILE" ]; then
  echo "==> Generating Secrets.swift from example..."
  cp "$SECRETS_EXAMPLE" "$SECRETS_FILE"
fi

ARGS=(test -project FlowQA.xcodeproj -scheme FlowQA
      -destination 'platform=macOS' -quiet)
FILTER="${1:-}"
[ -n "$FILTER" ] && ARGS+=(-only-testing:"FlowQATests/$FILTER")
xcodebuild "${ARGS[@]}"
